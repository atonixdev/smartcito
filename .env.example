# ============================================================================
# File: .env.example
# Purpose:
#   Template for environment variables. Copy to `.env` and fill in real values.
#   Never commit a populated `.env` — it is gitignored for safety.
# ============================================================================

# ---- Core ----
APP_ENV=development                 # development | staging | production
APP_NAME=SmartCito
APP_HOST=0.0.0.0
APP_PORT=8000
WEBAPP_PORT=5173
CAMERA_SERVICE_PORT=8010
GPS_SERVICE_PORT=8011
AI_SERVICE_PORT=8012
SECURITY_SERVICE_PORT=8013
HARDWARE_AGENT_PORT=8014
USB_MODULE_PORT=8015
INGESTION_KAFKA_PRODUCER_PORT=8100
INGESTION_SPARK_PORT=8101
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOG_LEVEL=INFO

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_JWT_SECRET=change-me-to-a-long-random-string
AUTH_ISSUER=smartcito.local
AUTH_AUDIENCE=smartcito-clients
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Database (PostgreSQL) ----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=smartcito
DB_USER=smartcito
DB_PASSWORD=change-me

# ---- Cache (Redis) ----
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
MEMCACHED_SERVERS=memcached-1:11211,memcached-2:11211,memcached-3:11211
MEMCACHED_DEFAULT_TTL_SECONDS=60
MEMCACHED_API_TTL_SECONDS=60
MEMCACHED_DASHBOARD_TTL_SECONDS=45
MEMCACHED_DEVICE_METADATA_TTL_SECONDS=300
MEMCACHED_AI_TTL_SECONDS=1800
MEMCACHED_SESSION_TTL_SECONDS=3600

# ---- Streaming (Kafka) ----
KAFKA_BROKER_URL=kafka:9092
MESSAGE_BUS_URL=kafka:9092
KAFKA_SENSOR_TOPIC=smartcito.sensors.raw
KAFKA_RAW_EVENTS_TOPIC=smartcito.events.raw
KAFKA_CLEAN_EVENTS_TOPIC=smartcito.events.clean
KAFKA_ALERTS_TOPIC=smartcito.alerts
# Set to true to publish every ingested reading to Kafka on startup.
KAFKA_PUBLISHER_ENABLED=false
KAFKA_PORT=9092
MQTT_PORT=1883

# ---- IoT ingestion (MQTT) ----
# Set MQTT_ENABLED=true to start the MQTT bridge in the API process.
MQTT_ENABLED=false
MQTT_HOST=mqtt
MQTT_TOPIC=smartcito/sensors/+
MQTT_CLIENT_ID=smartcito-api

# ---- Hardware simulation ----
SMARTCITO_DEPLOYMENT_MODE=development
CAMERA_SIMULATOR_PROFILE=default
GPS_SIMULATOR_PROFILE=default
USB_EMULATION_ENABLED=true

# ---- AI / object storage ----
AI_MODELS_URL=http://ai-service:8012
OBJECT_STORAGE_ENDPOINT=file://./data/object_storage
OBJECT_STORAGE_BUCKET=smartcito-artifacts

# ---- OpenStack deployment / infra ----
OPENSTACK_AUTH_URL=https://openstack.example.com:5000/v3
OPENSTACK_PROJECT=smartcito
OPENSTACK_USER=smartcito-admin
OPENSTACK_PASSWORD=change-me
OPENSTACK_REGION=RegionOne

# ---- Observability ----
AUDIT_LOG_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- Legacy compatibility aliases ----
# These remain for older scripts and images while services converge on the
# canonical names above.
SECRET_KEY=change-me-to-a-long-random-string
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=smartcito
POSTGRES_USER=smartcito
POSTGRES_PASSWORD=change-me
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ---- OpenStack deployment / infra ----
OPENSTACK_AUTH_URL=http://172.27.112.36/identity
OPENSTACK_PROJECT=Demo
OPENSTACK_PROJECT_ID=b4e15aaf3bcd41c69934f585febaa845
OPENSTACK_USER=admin
OPENSTACK_PASSWORD=48c95fc91bc43dee13634ee574af3ee8
OPENSTACK_REGION=RegionOne
OPENSTACK_USER_DOMAIN_NAME=Default
OPENSTACK_INTERFACE="public"
OPENSTACK_REGION=RegionOne

# ---- Observability ----
AUDIT_LOG_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- Legacy compatibility aliases ----
# These remain for older scripts and images while services converge on the
# canonical names above.
SECRET_KEY=change-me-to-a-long-random-string
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=smartcito
POSTGRES_USER=smartcito
POSTGRES_PASSWORD=change-me
KAFKA_BOOTSTRAP_SERVERS=kafka:9092


# --- Kaggle API (for AI training data) ---
KAGGLE_USERNAME=jackiedeven
KAGGLE_KEY=change-me-to-your-kaggle-api-key
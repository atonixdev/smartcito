{
  "name": "@orca/location-intelligence",
  "version": "1.0.0",
  "description": "Orca Location Intelligence Engine: country/region/area-code/IP/GPS fusion.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/server.js",
    "lint": "eslint . --ext .js --max-warnings=0",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "test": "node --test tests"
  },
  "dependencies": {
    "express": "^4.19.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}

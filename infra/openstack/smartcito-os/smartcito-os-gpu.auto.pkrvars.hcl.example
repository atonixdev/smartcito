auth_url             = "https://openstack.example.com:5000/v3"
project_name         = "smartcito"
username             = "smartcito-admin"
password             = "change-me"
region               = "RegionOne"
source_image_name    = "ubuntu-22.04"
image_name           = "smartcito-os-gpu-ubuntu-22.04-2026.05"
image_visibility     = "private"
build_flavor         = "g1.large"
build_network_id     = "services-network-id"
build_security_group = "smartcito-build"
ssh_username         = "ubuntu"
use_floating_ip      = true

node_exporter_version = "1.8.2"
fluent_bit_version    = "3.1.9"
kubernetes_version    = "1.30"

gpu_vendor            = "nvidia"
enable_nvidia_driver  = true
nvidia_driver_package = "nvidia-driver-550-server"
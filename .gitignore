# ============================================================================
# File: .gitignore
# Purpose: Keep the repository clean and safe from accidental secret leaks.
# ============================================================================

# ---- Secrets & environment ----
.env
.env.*
!.env.example
infra/terraform/.terraform/
infra/terraform/terraform.tfvars
infra/openstack/clouds.yaml
infra/terraform/orca-key.pem

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-keras/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# ---- Node / Webapp ----
node_modules/
webapp/dist/
webapp/.vite/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ---- IDE / OS ----
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ---- Docker / Data ----
.docker-data/
*.sqlite
*.db

# ---- Logs ----
*.log
logs/
